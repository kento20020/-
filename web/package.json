{
  "name": "roguelike-web",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "ローグライト Web版（TypeScript）。ブラウザで遊べる静的サイト（GitHub Pages）。数値真値は data.json、KPI/Botシムは Node で実行。",
  "engines": { "node": ">=22.6" },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --experimental-transform-types --test \"tests/**/*.test.ts\"",
    "sim": "node --experimental-transform-types scripts/sim.ts",
    "report": "node --experimental-transform-types scripts/report.ts",
    "gen-fixtures": "node --experimental-transform-types scripts/gen-fixtures.ts",
    "ab": "node --experimental-transform-types scripts/ab.ts",
    "sweep": "node --experimental-transform-types scripts/sweep.ts",
    "ev": "node --experimental-transform-types scripts/ev.ts",
    "search": "node --experimental-transform-types scripts/search-bot.ts",
    "tune": "node --experimental-transform-types scripts/tune.ts",
    "doctor": "node --experimental-transform-types scripts/doctor.ts",
    "check": "npm run doctor && npm run test && node --experimental-transform-types scripts/sim.ts --n 200 --assert-kpi && npm run build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "vite": "^6.0.7",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.2"
  }
}
